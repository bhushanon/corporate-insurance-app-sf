<?xml version="1.0" encoding="UTF-8"?>
<CustomObject xmlns="http://soap.sforce.com/2006/04/metadata">
    <label>Claim Attachment</label>
    <pluralLabel>Claim Attachments</pluralLabel>

    <nameField>
        <label>Claim Attachment Number</label>
        <type>AutoNumber</type>
        <displayFormat>CLM-ATT-{000000}</displayFormat>
    </nameField>

    <deploymentStatus>Deployed</deploymentStatus>

    <!-- Claim documents are sensitive -->
    <sharingModel>Private</sharingModel>

    <!-- Claim__c (parent) -->
    <fields>
        <fullName>Claim__c</fullName>
        <label>Claim</label>
        <type>Lookup</type>
        <referenceTo>Claim__c</referenceTo>
        <relationshipLabel>Claim Attachments</relationshipLabel>
        <relationshipName>ClaimAttachments</relationshipName>
        <required>true</required>
    </fields>

    <!-- Document_Type__c -->
    <fields>
        <fullName>Document_Type__c</fullName>
        <label>Document Type</label>
        <type>Picklist</type>
        <required>true</required>
        <picklist>
            <sorted>false</sorted>
            <picklistValues>
                <fullName>FNOL</fullName>
                <default>false</default>
            </picklistValues>
            <picklistValues>
                <fullName>Police Report</fullName>
                <default>false</default>
            </picklistValues>
            <picklistValues>
                <fullName>Medical Report</fullName>
                <default>false</default>
            </picklistValues>
            <picklistValues>
                <fullName>Invoice</fullName>
                <default>false</default>
            </picklistValues>
            <picklistValues>
                <fullName>Photo</fullName>
                <default>false</default>
            </picklistValues>
            <picklistValues>
                <fullName>Other</fullName>
                <default>true</default>
            </picklistValues>
        </picklist>
    </fields>

    <!-- Storage strategy (supports both Salesforce Files + legacy URL) -->

    <!-- ContentDocumentId__c (Salesforce Files link) -->
    <fields>
        <fullName>ContentDocumentId__c</fullName>
        <label>Content Document Id</label>
        <type>Text</type>
        <length>18</length>
        <required>false</required>
    </fields>

    <!-- Attachment_URL__c (legacy/external storage link) -->
    <fields>
        <fullName>Attachment_URL__c</fullName>
        <label>Attachment URL</label>
        <type>Url</type>
        <required>false</required>
    </fields>

    <!-- File_Name__c -->
    <fields>
        <fullName>File_Name__c</fullName>
        <label>File Name</label>
        <type>Text</type>
        <length>255</length>
        <required>false</required>
    </fields>

    <!-- File_Size_KB__c -->
    <fields>
        <fullName>File_Size_KB__c</fullName>
        <label>File Size (KB)</label>
        <type>Number</type>
        <precision>12</precision>
        <scale>0</scale>
        <required>false</required>
    </fields>

    <!-- MIME_Type__c -->
    <fields>
        <fullName>MIME_Type__c</fullName>
        <label>MIME Type</label>
        <type>Text</type>
        <length>100</length>
        <required>false</required>
    </fields>

    <!-- Audit -->
    <fields>
        <fullName>Uploaded_On__c</fullName>
        <label>Uploaded On</label>
        <type>DateTime</type>
        <required>false</required>
    </fields>

    <fields>
        <fullName>Uploaded_By__c</fullName>
        <label>Uploaded By</label>
        <type>Lookup</type>
        <referenceTo>User</referenceTo>
        <relationshipLabel>Claim Attachments Uploaded</relationshipLabel>
        <relationshipName>ClaimAttachmentsUploaded</relationshipName>
        <required>false</required>
    </fields>

    <!-- Notes -->
    <fields>
        <fullName>Description__c</fullName>
        <label>Description</label>
        <type>LongTextArea</type>
        <length>32768</length>
        <visibleLines>4</visibleLines>
        <required>false</required>
    </fields>

    <!-- Status -->
    <fields>
        <fullName>Is_Active__c</fullName>
        <label>Is Active</label>
        <type>Checkbox</type>
        <defaultValue>true</defaultValue>
    </fields>

</CustomObject>