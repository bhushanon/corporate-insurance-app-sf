<?xml version="1.0" encoding="UTF-8"?>
<CustomObject xmlns="http://soap.sforce.com/2006/04/metadata">
    <label>Import Batch</label>
    <pluralLabel>Import Batches</pluralLabel>

    <nameField>
        <label>Batch Name</label>
        <type>Text</type>
    </nameField>

    <deploymentStatus>Deployed</deploymentStatus>

    <!-- Legacy-style: import/batch tracking is admin-only -->
    <sharingModel>Private</sharingModel>

    <!-- Status__c -->
    <fields>
        <fullName>Status__c</fullName>
        <label>Status</label>
        <type>Picklist</type>
        <required>true</required>
        <picklist>
            <sorted>false</sorted>
            <picklistValues>
                <fullName>New</fullName>
                <default>true</default>
            </picklistValues>
            <picklistValues>
                <fullName>In Progress</fullName>
                <default>false</default>
            </picklistValues>
            <picklistValues>
                <fullName>Completed</fullName>
                <default>false</default>
            </picklistValues>
            <picklistValues>
                <fullName>Completed with Errors</fullName>
                <default>false</default>
            </picklistValues>
            <picklistValues>
                <fullName>Failed</fullName>
                <default>false</default>
            </picklistValues>
        </picklist>
    </fields>

    <!-- Employer__c (optional scope: which employer's employee roster this import is for) -->
    <fields>
        <fullName>Employer__c</fullName>
        <label>Employer</label>
        <type>Lookup</type>
        <referenceTo>Employer__c</referenceTo>
        <relationshipLabel>Import Batches</relationshipLabel>
        <relationshipName>ImportBatches</relationshipName>
        <required>false</required>
    </fields>

    <!-- Source_File_Name__c -->
    <fields>
        <fullName>Source_File_Name__c</fullName>
        <label>Source File Name</label>
        <type>Text</type>
        <length>255</length>
        <required>false</required>
    </fields>

    <!-- Source_File_Type__c -->
    <fields>
        <fullName>Source_File_Type__c</fullName>
        <label>Source File Type</label>
        <type>Picklist</type>
        <required>false</required>
        <picklist>
            <sorted>false</sorted>
            <picklistValues>
                <fullName>CSV</fullName>
                <default>true</default>
            </picklistValues>
            <picklistValues>
                <fullName>XLS</fullName>
                <default>false</default>
            </picklistValues>
            <picklistValues>
                <fullName>XLSX</fullName>
                <default>false</default>
            </picklistValues>
            <picklistValues>
                <fullName>Other</fullName>
                <default>false</default>
            </picklistValues>
        </picklist>
    </fields>

    <!-- Total_Records__c -->
    <fields>
        <fullName>Total_Records__c</fullName>
        <label>Total Records</label>
        <type>Number</type>
        <precision>10</precision>
        <scale>0</scale>
        <required>false</required>
    </fields>

    <!-- Success_Count__c -->
    <fields>
        <fullName>Success_Count__c</fullName>
        <label>Success Count</label>
        <type>Number</type>
        <precision>10</precision>
        <scale>0</scale>
        <required>false</required>
    </fields>

    <!-- Error_Count__c -->
    <fields>
        <fullName>Error_Count__c</fullName>
        <label>Error Count</label>
        <type>Number</type>
        <precision>10</precision>
        <scale>0</scale>
        <required>false</required>
    </fields>

    <!-- Started_On__c -->
    <fields>
        <fullName>Started_On__c</fullName>
        <label>Started On</label>
        <type>DateTime</type>
        <required>false</required>
    </fields>

    <!-- Completed_On__c -->
    <fields>
        <fullName>Completed_On__c</fullName>
        <label>Completed On</label>
        <type>DateTime</type>
        <required>false</required>
    </fields>

    <!-- Initiated_By__c (Lookup to User) -->
    <fields>
        <fullName>Initiated_By__c</fullName>
        <label>Initiated By</label>
        <type>Lookup</type>
        <referenceTo>User</referenceTo>
        <relationshipLabel>Initiated Import Batches</relationshipLabel>
        <relationshipName>InitiatedImportBatches</relationshipName>
        <required>false</required>
    </fields>

    <!-- Notes__c -->
    <fields>
        <fullName>Notes__c</fullName>
        <label>Notes</label>
        <type>LongTextArea</type>
        <length>32768</length>
        <visibleLines>6</visibleLines>
        <required>false</required>
    </fields>

</CustomObject>